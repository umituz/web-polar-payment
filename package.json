{
  "name": "@umituz/web-polar-payment",
  "version": "1.0.12",
  "description": "Universal Polar.sh subscription billing — Firebase adapter",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./domain": "./src/domain/index.ts",
    "./infrastructure": "./src/infrastructure/index.ts",
    "./presentation": "./src/presentation/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external firebase --external firebase/functions --external firebase/firestore",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external firebase --external firebase/functions --external firebase/firestore",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "version:patch": "npm version patch -m 'chore: release v%s'",
    "version:minor": "npm version minor -m 'chore: release v%s'",
    "version:major": "npm version major -m 'chore: release v%s'"
  },
  "keywords": [
    "polar",
    "subscription",
    "billing",
    "firebase",
    "react"
  ],
  "author": "umituz",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "firebase": "^12.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
